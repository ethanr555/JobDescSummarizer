{
    "manifest_version": 2,
    "name": "Job Description Summarizer",
    "version": "1.0",

    "description": "Browser Extension component of the Job Description Summarizer project.",
    "icons": {
        "48": "icon/icon.svg",
        "96": "icon/icon.svg"
    },

    "permissions": [
        "activeTab",
        "storage"
    ],

    "browser_action": {
        "default_icon": "icon/icon.svg",
        "default_title": "Job Summarizer Settings",
        "default_popup": "extensionConfig/config.html"
    },

    "content_scripts": [
        {
            "matches": [
                "*://*.indeed.com/*",
                "*://*.linkedin.com/*"
            ],
            "js": [
                "contentScripts/content.js"
            ]
        }
    ],

    "web_accessible_resources": [
        "icon/icon.svg",
        "icon/icon_48px/png",
        "icon/icon_96px/png"
    ]

     
}